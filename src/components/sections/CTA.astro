---
import Container from "../shared/Container.astro";
import BtnLink from "../shared/BtnLink.astro";
---

<section id="contact" class="pb-20">
    <Container>
        <div class="w-full relative py-12 md:py-16 px-6 md:px-10 rounded-3xl bg-box-bg border border-box-border overflow-hidden">
            <!-- Glow effects -->
            <span class="absolute top-0 right-0 w-64 h-64 bg-primary/10 rounded-full blur-3xl pointer-events-none"></span>
            <span class="absolute bottom-0 left-0 w-48 h-48 bg-primary/8 rounded-full blur-3xl pointer-events-none"></span>

            <div class="relative mx-auto text-center max-w-2xl">
                <div class="flex items-center justify-center gap-3 mb-4">
                    <span class="w-8 h-px bg-primary"></span>
                    <span class="text-primary text-sm font-semibold tracking-widest uppercase">Get Started</span>
                    <span class="w-8 h-px bg-primary"></span>
                </div>

                <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-heading-1 leading-tight">
                    Let's Build Your <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-pink-400">Smart Space</span>
                </h2>

                <p class="mt-6 text-lg text-heading-3 leading-relaxed">
                    Tell us about your project and we'll put together a tailored solution — from a single smart room to a full multi-building deployment.
                </p>

                <div class="mt-8 flex flex-wrap gap-4 justify-center">
                    <BtnLink text="Request a Consultation" href="mailto:info@iewah.com" variant="primary" className="font-medium"/>
                    <a href="tel:+97143204228" class="px-6 py-3 rounded-full border border-box-border text-heading-2 hover:border-primary/60 hover:text-primary transition-colors duration-300 font-medium flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                        </svg>
                        +971 4 320 4228
                    </a>
                </div>

                <div class="mt-8 flex flex-wrap justify-center gap-6 text-sm text-heading-3">
                    <span class="flex items-center gap-1.5">
                        <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                        Abu Dhabi &amp; Dubai
                    </span>
                    <span class="flex items-center gap-1.5">
                        <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                        ISO-compliant installations
                    </span>
                    <span class="flex items-center gap-1.5">
                        <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                        24/7 client support
                    </span>
                </div>
            </div>
        </div>
    </Container>
</section>
