---
import Container from "../shared/Container.astro";

const sectors = [
    {
        title: "Luxury Villas",
        desc: "Full home automation — lighting, climate, security and entertainment — delivered as one elegant, easy-to-use system.",
        icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>`,
    },
    {
        title: "Commercial Offices",
        desc: "Integrated security and access-control systems tailored to business operations and compliance needs.",
        icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" /></svg>`,
    },
    {
        title: "Hospitality Projects",
        desc: "GRMS and BMS implementations that create seamless, efficient and memorable guest experiences.",
        icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>`,
    },
    {
        title: "Residential Buildings",
        desc: "Full ELV systems across multi-unit developments — enhancing security, convenience and energy efficiency.",
        icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" /></svg>`,
    },
];
---

<section id="sectors" class="relative">
    <Container className="space-y-10">
        <div class="max-w-3xl">
            <div class="flex items-center gap-3 mb-4">
                <span class="w-8 h-px bg-primary"></span>
                <span class="text-primary text-sm font-semibold tracking-widest uppercase">Built for Every Environment</span>
            </div>
            <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-heading-1 leading-tight">
                Where We <span class="text-primary">Work</span>
            </h2>
            <p class="mt-4 text-lg text-heading-3 max-w-2xl">
                From private villas to operating hotels, our solutions adapt to the demands of each setting — and to the heat, humidity and standards of the UAE.
            </p>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
            {sectors.map(sector => (
                <div class="p-6 rounded-2xl bg-box-bg border border-box-border hover:border-primary/30 transition-colors duration-300">
                    <div class="w-12 h-12 rounded-xl bg-primary/15 flex items-center justify-center text-primary mb-4">
                        <Fragment set:html={sector.icon} />
                    </div>
                    <h3 class="font-semibold text-heading-1 text-lg mb-2">{sector.title}</h3>
                    <p class="text-sm text-heading-3 leading-relaxed">{sector.desc}</p>
                </div>
            ))}
        </div>
    </Container>
</section>
