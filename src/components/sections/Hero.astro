---
import Container from "../shared/Container.astro";
import BtnLink from "../shared/BtnLink.astro";

const tags = [
    "Smart Home Automation",
    "Lighting & Climate Control",
    "Guest Room Management",
    "Security & Surveillance",
    "Building Management",
];
---

<section class="relative pt-36 lg:pt-44 pb-20 overflow-hidden">
    <!-- Background glow effects -->
    <span class="absolute top-0 left-0 w-full h-2/3 bg-gradient-to-b from-primary/8 to-transparent pointer-events-none"></span>
    <span class="absolute top-16 left-1/4 w-80 h-80 bg-primary/10 rounded-full blur-3xl pointer-events-none"></span>
    <span class="absolute top-32 right-1/4 w-60 h-60 bg-primary/6 rounded-full blur-3xl pointer-events-none"></span>
    <span class="absolute -top-10 right-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl pointer-events-none"></span>

    <Container className="flex flex-col items-center text-center relative z-10">
        <!-- Location badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-primary/30 bg-primary/10 text-primary text-sm font-medium mb-8">
            <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
            United Arab Emirates &nbsp;·&nbsp; Abu Dhabi &nbsp;·&nbsp; Dubai
        </div>

        <!-- Main headline -->
        <h1 class="text-4xl/tight sm:text-5xl/tight md:text-6xl/tight xl:text-7xl/tight font-bold text-heading-1 max-w-4xl">
            Smart Homes,
            <span class="block text-transparent bg-clip-text bg-gradient-to-r from-primary to-pink-400">
                Intelligently Connected.
            </span>
        </h1>

        <p class="mt-7 text-lg md:text-xl text-heading-3 max-w-2xl leading-relaxed">
            Integrated Electrical Works &amp; Home Automation — delivering security, lighting, climate control and full building management across the UAE.
        </p>

        <!-- CTA buttons -->
        <div class="mt-10 flex flex-wrap gap-4 justify-center">
            <BtnLink text="Request a Consultation" href="#contact" variant="primary" className="min-w-max font-medium"/>
            <a href="#services" class="px-6 py-3 rounded-full border border-box-border text-heading-2 hover:border-primary/60 hover:text-primary transition-colors duration-300 font-medium">
                Our Services
            </a>
        </div>

        <!-- Service tags -->
        <div class="mt-14 flex flex-wrap gap-3 justify-center max-w-2xl">
            {tags.map(tag => (
                <span class="px-4 py-1.5 text-sm rounded-full border border-box-border text-heading-3 bg-box-bg font-medium tracking-wide">
                    {tag}
                </span>
            ))}
        </div>
    </Container>
</section>
