---
import Container from "../shared/Container.astro";

const expertise = [
    {
        number: "01",
        title: "Security Systems",
        description: "CCTV surveillance, access control (ACS), gate barriers, sliding gates and doors, intercom and intruder alarms — scalable from a single entrance to an entire estate.",
        icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
    },
    {
        number: "02",
        title: "Automation",
        description: "Lighting control (LCS), building management (BMS), guest room management (GRMS) and full home automation — programmable, app- and voice-controlled, energy-aware.",
        icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>`,
    },
    {
        number: "03",
        title: "Integrated Solutions",
        description: "Seamless integration of security and automation across protocols and vendors — harmonized into one platform for optimal functionality and a single, intuitive user experience.",
        icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>`,
    },
];

const benefits = [
    "One interface for every system",
    "Lower energy and running costs",
    "Scales with the project",
];
---

<section id="services" class="relative">
    <Container className="space-y-12">
        <div class="max-w-3xl">
            <div class="flex items-center gap-3 mb-4">
                <span class="w-8 h-px bg-primary"></span>
                <span class="text-primary text-sm font-semibold tracking-widest uppercase">What We Do</span>
            </div>
            <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-heading-1 leading-tight">
                Our <span class="text-primary">Expertise</span>
            </h2>
            <p class="mt-4 text-lg text-heading-3 max-w-2xl">
                Home automation at the core, with security and integration built around it. Whether a single smart villa or a multi-building campus, IEWAH unifies every system into one seamless, intelligent experience.
            </p>
        </div>

        <div class="space-y-4">
            {expertise.map(item => (
                <div class="flex flex-col sm:flex-row items-start gap-5 p-6 sm:p-7 rounded-2xl bg-box-bg border border-box-border hover:border-primary/30 transition-colors duration-300">
                    <div class="flex-shrink-0 w-14 h-14 rounded-xl bg-primary/15 flex items-center justify-center text-primary">
                        <Fragment set:html={item.icon} />
                    </div>
                    <div class="flex-1">
                        <h3 class="text-xl font-semibold text-heading-1 mb-2">{item.title}</h3>
                        <p class="text-heading-3 leading-relaxed">{item.description}</p>
                    </div>
                    <div class="hidden sm:block text-4xl font-bold text-heading-3/30 self-center">{item.number}</div>
                </div>
            ))}
        </div>

        <!-- Why Integration Matters -->
        <div class="p-6 rounded-2xl border border-box-border bg-box-bg/50">
            <p class="text-xs tracking-widest uppercase text-heading-3 font-semibold mb-4">Why Integration Matters</p>
            <div class="flex flex-wrap gap-x-8 gap-y-3">
                {benefits.map(b => (
                    <div class="flex items-center gap-2 text-heading-2">
                        <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                        <span class="text-sm font-medium">{b}</span>
                    </div>
                ))}
            </div>
        </div>
    </Container>
</section>
