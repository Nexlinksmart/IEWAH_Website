---
import Service from "../cards/Service.astro";
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";
import Title from "../shared/Title.astro";
import { services } from "../../utils/data.ts";

type ServicesProps = {
    title: string;
    description: string;
    icon: string;
};
---

<section id="services">
    <Container className="space-y-10 md:space-y-12">
        <div class="text-center max-w-3xl mx-auto space-y-4">
            <Title>
                What We Offer
            </Title>
            <Paragraph>
                Home automation at the core, with security and integration built around it — one seamless, intelligent experience.
            </Paragraph>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
            {services.map((service: ServicesProps) => (
                <Service title={service.title} description={service.description} icon={service.icon} />
            ))}
        </div>
    </Container>
</section>
