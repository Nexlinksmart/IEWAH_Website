---
import Container from "../shared/Container.astro";

const stats = [
    { value: "50+", label: "Projects Delivered" },
    { value: "5", label: "Core Disciplines" },
    { value: "6+", label: "Certified Platforms" },
    { value: "24/7", label: "Client Support" },
];
---

<section class="relative mt-4 md:mt-8">
    <Container>
        <div class="mx-auto lg:mx-0 p-6 sm:p-8 max-w-5xl rounded-3xl bg-box-bg border border-box-border shadow-lg shadow-box-shadow md:divide-x divide-box-border grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-8">
            {stats.map(stat => (
                <div class="text-center px-2">
                    <h2 class="font-bold text-2xl sm:text-3xl md:text-4xl text-primary">
                        {stat.value}
                    </h2>
                    <p class="mt-2 text-sm sm:text-base text-heading-3 tracking-wide uppercase font-medium">{stat.label}</p>
                </div>
            ))}
        </div>
    </Container>
</section>
