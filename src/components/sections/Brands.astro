---
import Container from "../shared/Container.astro";
import Title from "../shared/Title.astro";

const platforms = [
    { name: "KNX", sub: "Building Control" },
    { name: "Helvar", sub: "Lighting" },
    { name: "Philips Dynalite", sub: "Lighting Control" },
    { name: "RTI", sub: "Automation" },
    { name: "DALI-2", sub: "Lighting Protocol" },
    { name: "BMS / GRMS", sub: "Integration" },
];
---

<section>
    <Container className="space-y-8">
        <div class="text-center max-w-3xl mx-auto">
            <Title>
                Certified Platforms
            </Title>
        </div>
        <div class="flex justify-center flex-wrap gap-4">
            {platforms.map(p => (
                <div class="p-4 sm:p-5 rounded-xl bg-body border border-box-border group text-center min-w-[120px]">
                    <p class="font-semibold text-heading-1 ease-linear duration-300 group-hover:text-primary group-hover:scale-105 transition-all">{p.name}</p>
                    <p class="text-xs text-heading-3 mt-1 tracking-wide uppercase">{p.sub}</p>
                </div>
            ))}
        </div>
    </Container>
</section>
