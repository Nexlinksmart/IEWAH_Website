---
---

<div id="chat-widget" class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-3">
    <!-- Tooltip label -->
    <div id="chat-label" class="hidden sm:flex items-center gap-2 bg-box-bg border border-box-border rounded-full px-4 py-2 shadow-lg text-sm font-medium text-heading-2 opacity-0 translate-y-2 transition-all duration-300">
        <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
        Chat with us
    </div>

    <!-- Chat button -->
    <button
        id="chat-btn"
        aria-label="Chat with us"
        class="group relative w-14 h-14 rounded-full bg-primary shadow-lg shadow-primary/30 flex items-center justify-center text-white hover:scale-105 active:scale-95 transition-all duration-300 overflow-hidden"
    >
        <!-- Hover glow ring -->
        <span class="absolute inset-0 rounded-full bg-white/10 scale-0 group-hover:scale-100 transition-transform duration-300"></span>

        <!-- Chat icon -->
        <svg id="chat-icon" class="w-6 h-6 relative z-10 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
        </svg>

        <!-- "Chat with us" label inside button on mobile -->
        <span class="sr-only">Chat with us</span>
    </button>
</div>

<!-- Inline label shown next to the button (always visible) -->
<div class="fixed bottom-[1.85rem] right-20 z-50 pointer-events-none">
    <div class="flex items-center gap-2 bg-box-bg border border-box-border rounded-full px-4 py-2.5 shadow-lg text-sm font-medium text-heading-2 whitespace-nowrap">
        <span class="w-2 h-2 rounded-full bg-primary animate-pulse flex-shrink-0"></span>
        Chat with us
    </div>
</div>

<script>
    const btn = document.getElementById("chat-btn");
    if (btn) {
        btn.addEventListener("click", () => {
            // Phase 2: chatbot integration goes here
            // For now, open email
            window.location.href = "mailto:info@iewah.com?subject=Chat enquiry";
        });
    }
</script>
