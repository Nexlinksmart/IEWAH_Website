---
import "../styles/global.css"
import Layout from '../layouts/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import ByNumber from '../components/sections/ByNumber.astro';
import AboutUs from '../components/sections/AboutUs.astro';
import Services from '../components/sections/Services.astro';
import Features from '../components/sections/Features.astro';
import Capabilities from '../components/sections/Capabilities.astro';
import Process from '../components/sections/Process.astro';
import Sectors from '../components/sections/Sectors.astro';
import WhyUs from '../components/sections/WhyUs.astro';
import Brands from '../components/sections/Brands.astro';
import CTA from '../components/sections/CTA.astro';
